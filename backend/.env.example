# INT-Slim backend environment template
# Copy this file to backend/.env and fill in real values.

# Database
mysql_host=localhost
mysql_port=3306
mysql_user=root
mysql_password=
mysql_database=xbots_v2
mysql_charset=utf8mb4

# JWT
secret_key=replace-with-a-long-random-secret
algorithm=HS256
access_token_expire_days=1

# LLM providers
deepseek_api_key=
minimax_api_key=
aliyun_bailian_api_key=
siliconflow_api_key=
alibaba_cloud_access_key_id=
alibaba_cloud_access_key_secret=

# Web search
tavily_api_key=

# Email
smtp_server=smtp.qq.com
smtp_port=465
smtp_username=
smtp_password=
email_from=
email_subject_prefix=[INT-Slim]
